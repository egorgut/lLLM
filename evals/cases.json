  {
    "id": "sql-recovery-001",
    "category": "sql_recovery",
    "modes": ["scripted"],
    "prompt": "Query the Track table for the count of rows (the harness forces one bad query first).",
    "script": [
      {"tool_call": {"name": "sql_query", "arguments": {"query": "SELECT COUNT(*) FROM NoSuchTable"}}},
      {"tool_call": {"name": "sql_query", "arguments": {"query": "SELECT COUNT(*) FROM Track"}}},
      {"text": "There are 3503 tracks in the database."}
    ],
    "tool_results": {
      "sql_query": [
        {"ok": false, "error": {"type": "sql_no_such_table", "message": "no such table: NoSuchTable"}},
        {"ok": true, "columns": ["COUNT(*)"], "rows": [[3503]]}
      ]
    },
    "expectation": {
      "status": "completed",
      "reason": "final_answer",
      "required_tools": ["sql_query"],
      "min_tool_calls": 2,
      "max_tool_calls": 2
    }
  },
  {
    "id": "multi-tool-001",
    "category": "multi_tool",
    "modes": ["scripted", "live"],
    "prompt": "How many employees are in the database, multiplied by 12? Reply with the number.",
    "script": [
      {"tool_call": {"name": "sql_query", "arguments": {"query": "SELECT COUNT(*) FROM Employee"}}},
      {"tool_call": {"name": "python_calculate", "arguments": {"expression": "12 * 8"}}},
      {"text": "The result is 96."}
    ],
    "tool_results": {
      "sql_query": {"ok": true, "columns": ["COUNT(*)"], "rows": [[8]]},
      "python_calculate": {"ok": true, "result": 96}
    },
    "expectation": {
      "status": "completed",
      "reason": "final_answer",
      "required_tools": ["sql_query", "python_calculate"],
      "min_tool_calls": 2,
      "max_tool_calls": 2,
      "answer_matches": "96"
    }
  },
