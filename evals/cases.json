  {
    "id": "skill-explicit-001",
    "category": "skill_explicit",
    "modes": ["scripted"],
    "skill_case": true,
    "prompt": "Use the sales_analysis skill to find which genre earns the most revenue.",
    "route": [],
    "script": [
      {"tool_call": {"name": "sql_query", "arguments": {"query": "SELECT g.Name, SUM(il.UnitPrice*il.Quantity) AS r FROM InvoiceLine il JOIN Track t ON il.TrackId=t.TrackId JOIN Genre g ON t.GenreId=g.GenreId GROUP BY g.Name ORDER BY r DESC LIMIT 1"}}},
      {"text": "Rock generated the most revenue: $826.65. Basis: revenue = UnitPrice x Quantity, grouped by genre. Limitation: local Chinook sample database."}
    ],
    "tool_results": {
      "sql_query": {"ok": true, "columns": ["Name", "r"], "rows": [["Rock", 826.65]], "row_count": 1, "truncated": false}
    },
    "expectation": {
      "expected_selection": "sales_analysis",
      "selection_source": "explicit",
      "status": "completed",
      "reason": "final_answer",
      "required_tools": ["sql_query"],
      "forbidden_tools": ["mcp_time__get_current_time"],
      "answer_contains": ["revenue"]
    }
  },
